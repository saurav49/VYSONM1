generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Tier {
  HOBBY
  ENTERPRISE
}

model UrlShortener {
  id          Int      @id @default(autoincrement())
  user        User?     @relation(fields: [userId], references: [id])
  userId      Int?
  originalUrl String   
  shortCode   String   @unique
  password    String?
  clicks      Int      @default(0)
  lastAccessedAt DateTime? @db.Timestamptz(6)
  expiryDate DateTime? @db.Timestamptz(6)
  
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)
}

model User {
  id      Int @id @default(autoincrement())
  email   String @unique
  name    String?
  apiKey  String @unique
  shortens UrlShortener[]
  tier     Tier  @default(HOBBY)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  deletedAt   DateTime? @db.Timestamptz(6)
}

model RequestLogging {
  id      Int @id @default(autoincrement())
  method   String?
  timestamp    String?
  userAgent    String?
  url    String?
  ip    String?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
}
